// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  /// Optional UI tint for board and project cards, e.g. `#6366f1`
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  statuses   ProjectStatus[]
  priorities ProjectPriority[]
  labels     ProjectLabel[]
  tasks      Task[]

  @@index([userId])
}

model ProjectStatus {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int     @default(0)
  isFinal   Boolean @default(false)

  tasks Task[]

  @@unique([projectId, name])
  @@index([projectId])
}

model ProjectPriority {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int     @default(0)

  tasks Task[]

  @@unique([projectId, name])
  @@index([projectId])
}

model ProjectLabel {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  color     String

  taskLabels TaskLabel[]

  @@unique([projectId, name])
  @@index([projectId])
}

model Task {
  id          String          @id @default(cuid())
  projectId   String
  project     Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  statusId    String
  status      ProjectStatus   @relation(fields: [statusId], references: [id], onDelete: Restrict)
  priorityId  String
  priority    ProjectPriority @relation(fields: [priorityId], references: [id], onDelete: Restrict)
  position    Float           @default(0)
  dueDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  labels      TaskLabel[]
  subtasks    Subtask[]
  attachments Attachment[]
  comments    Comment[]
  activities  ActivityEvent[]

  @@index([projectId])
  @@index([statusId])
  @@index([priorityId])
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   ProjectLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

model Subtask {
  id        String  @id @default(cuid())
  taskId    String
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String
  completed Boolean @default(false)
  position  Int     @default(0)

  @@index([taskId])
}

model Attachment {
  id          String  @id @default(cuid())
  taskId      String
  task        Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url         String
  filename    String?
  contentType String?
  size        Int?

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model ActivityEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String
  metadata  Json?
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId String?

  @@index([taskId])
  @@index([projectId])
}

/// Saved inbox table layout (filters, sort, columns, grouping) per Clerk user and surface (e.g. project board vs projects list).
model UserInboxPreferences {
  id        String   @id @default(cuid())
  userId    String
  /// e.g. `projects-overview` or `project:<projectId>`
  scope     String
  prefsJson Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, scope])
  @@index([userId])
}
